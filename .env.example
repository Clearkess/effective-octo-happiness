APP_ENV=production
DEBUG=false
PORT=8000
SESSION_DAYS=14
MAX_UPLOAD_MB=16

# Use PostgreSQL in production. Example:
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>

# Optional local SQLite override for development:
# SQLITE_PATH=/app/data/blockharbor.db

UPLOAD_ROOT=/app/data/uploads/kyc
ADMIN_EMAIL=change-me@example.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
